--===== دوال مساعدة =====--
local function createButton(name, y)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 260, 0, 40)
    btn.Position = UDim2.new(0, 30, 0, y)
    btn.BackgroundColor3 = GRAY_COLOR
    btn.Text = name
    btn.TextColor3 = RED_COLOR -- نص أحمر
    btn.Font = Enum.Font.GothamSemibold
    btn.TextScaled = true
    btn.BorderColor3 = RED_COLOR -- الحدود حمراء
    btn.Parent = main
    return btn
end

local function createCounter(y)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0, 260, 0, 20)
    lbl.Position = UDim2.new(0, 30, 0, y)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = RED_COLOR -- نص أحمر
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextScaled = true
    lbl.Text = "Collected: 0"
    lbl.Parent = main
    return lbl
end

-- الإحداثيات المستهدفة للانتقال
local TARGET_X = -118.8
local TARGET_Y = 21.5   
local TARGET_Z = 245.5

-- وظيفة الانتقال الفوري الجديدة
local function TeleportToTarget()
    if LocalPlayer and LocalPlayer.Character then
        local HRP = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if HRP then
            local TargetCFrame = CFrame.new(TARGET_X, TARGET_Y, TARGET_Z)
            HRP.CFrame = TargetCFrame
            print("✅ تم الانتقال بنجاح إلى الموقع: X:" .. TARGET_X .. ", Y:" .. TARGET_Y .. ", Z:" .. TARGET_Z)
        else
            print("⚠️ HumanoidRootPart غير موجود. الرجاء التأكد من تحميل شخصيتك بالكامل.")
        end
    else
        print("⚠️ لم يتم العثور على اللاعب المحلي.")
    end
end

-- زر الإنتقال الجديد (تم تعديل النص)
local teleportBtn = createButton("اول شي اكبس هنا و ينقلك عشان تكبس عل اول زر phone بعده ابدا", 60) 
-- زر وتجميع الهاتف (تم تعديل النص)
local phoneAutoBtn = createButton("هسا ابدا بل تدمير ZERO", 110)
local phoneCounter = createCounter(160)


--===== وظائف التحكم المدمجة: الشخصية والأدوات =====--

-- وظيفة إخفاء الشخصية وإزالتها من Workspace
local function HideCharacter()
    local char = LocalPlayer.Character
    if char and char.Parent ~= hiddenCharacterFolder then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.Health = 0
        end
        char.Parent = hiddenCharacterFolder
    end
end

-- وظيفة إظهار الشخصية واستعادتها إلى Workspace
local function ShowCharacter()
    local char = LocalPlayer.Character
    if char and char.Parent == hiddenCharacterFolder then
        char.Parent = Workspace
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.Health = humanoid.MaxHealth 
        end
    end
end

-- وظيفة التخلص من الأدوات (ClearTools)
local function ClearTools()
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            tool:Destroy()
        end
    end
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") then
                tool:Destroy()
            end
        end
    end
end

-- وظيفة عد الأدوات
local function CountTool(toolName)
    local count = 0
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.Name == toolName then
            count = count + 1
        end
    end
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool.Name == toolName then
                count = count + 1
            end
        end
    end
    return count
end

local hasStartedDuping = {} 

--===== البحث عن الهاتف =====--
local function getPhone()
    local p = Workspace:FindFirstChild("WorkspaceCom")
    if not p then return end
    local store = p:FindFirstChild("001_CommercialStores")
    if not store then return end
    local c1 = store:FindFirstChild("CommercialStorage1")
    if not c1 then return end
    local tools = c1:FindFirstChild("Store") and c1.Store:FindFirstChild("Tools")
    if not tools then return end
    return tools:FindFirstChild("Iphone")
end

--===== وظائف الجمع =====--
local phoneCount = 0
local phoneAuto = false
local lastTick = 0
-- ====== وظائف الجمع المطورة ====== --
local phoneCount = 0
local phoneAuto = true -- تفعيل التلقائي
local lastTick = 0
local interval = 0.01  -- سرعة استجابة قصوى (أقل من الإطار الواحد)
local intensity = 500  -- قيمة فعالة جداً ولا تسبب حظر السيرفر للطلبات

local function safeFireClick(detector, times)
    if not detector then return end
    
    -- استخدام task.spawn لتنفيذ العمليات في خلفية السكربت دون تعطيله
    task.spawn(function()
        for i = 1, times do
            -- استخدام fireclickdetector مباشرة إذا كان متاحاً
            pcall(function() 
                fireclickdetector(detector, 0) 
            end)
        end
    end)
end

local function collectPhone()
    local player = game.Players.LocalPlayer
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    
    -- البحث عن الهاتف (تأكد من وجود وظيفة getPhone لديك)
    local phone = getPhone() 
    
    if phone and root then
        local detector = phone:FindFirstChildOfClass("ClickDetector")
        
        if detector then
            -- الانتقال السريع لموقع الهاتف (Teleport)
            root.CFrame = phone.CFrame + Vector3.new(0, 3, 0)
            
            -- تنفيذ النقرات السريعة
            safeFireClick(detector, intensity)
            phoneCount = phoneCount + 1
            print("تم جمع الهاتف رقم: " .. phoneCount)
        end
    end
end

        
        local toolName = "Iphone" 
        local count = CountTool(toolName)
        if count > 0 and not hasStartedDuping[toolName] then
            hasStartedDuping[toolName] = true
            HideCharacter() 
        end
    end
end

--===== Advanced Anti-Lag (Player + All Tools Hide) - تم التحديث =====--
local savedObjects = {}

local function hideEverythingAroundPlayer(hide)
    if hide then
        ClearTools() 
    else
        ShowCharacter() 
    end
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            if hide then
                savedObjects[obj] = {Transparency=obj.Transparency, CanCollide=obj.CanCollide}
                obj.Transparency = 1
                obj.CanCollide = false
            elseif savedObjects[obj] then
                obj.Transparency = savedObjects[obj].Transparency
                obj.CanCollide = savedObjects[obj].CanCollide
                savedObjects[obj] = nil
            end
        end
    end

    local function hideAllPlayerTools(container)
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                for _, part in ipairs(tool:GetDescendants()) do
                    if part:IsA("BasePart") then
                        if hide then
                            savedObjects[part] = {Transparency=part.Transparency, CanCollide=part.CanCollide}
                            part.Transparency = 1
                            part.CanCollide = false
                        elseif savedObjects[part] then
                            part.Transparency = savedObjects[part].Transparency
                            part.CanCollide = savedObjects[part].CanCollide
                            savedObjects[part] = nil
                        end
                    end
                end
            end
        end
    end

    hideAllPlayerTools(LocalPlayer.Backpack)        
    if LocalPlayer.Character then
        hideAllPlayerTools(LocalPlayer.Character)   
    end
    local toolsFolder = Workspace:FindFirstChild("Tools")
    if toolsFolder then
        hideAllPlayerTools(toolsFolder)             
    end
end

--===== تفاعلات الأزرار =====--

-- تفاعل زر Teleport
teleportBtn.MouseButton1Click:Connect(function()
    TeleportToTarget()
end)

-- تفاعل زر Auto Phone 
phoneAutoBtn.MouseButton1Click:Connect(function()
    phoneAuto = not phoneAuto
    -- تعديل نص الزر عند الإيقاف والتشغيل
    phoneAutoBtn.Text = phoneAuto and "🛑 اوقف التدمير" or "هسا ابدا بل تدمير JR"
    
    if not phoneAuto then
        hasStartedDuping = {} 
    end
    
    hideEverythingAroundPlayer(phoneAuto)
end)


--===== حلقة التجميع =====--
RunService.Heartbeat:Connect(function()
    if tick() - lastTick >= interval then
        lastTick = tick()
        if phoneAuto then
            collectPhone()
            phoneCount = phoneCount + intensity
            phoneCounter.Text = "Collected: " .. tostring(phoneCount)
        end
    end
end)

--===== تفعيل واجهة JR =====--
toggle.MouseButton1Click:Connect(function()
    main.Visible = not main.Visible
end)

--===== التحقق من المفتاح =====--
confirmKey.MouseButton1Click:Connect(function()
    if keyBox.Text == "ZERO3MK" then
        keyFrame.Visible = false
        toggle.Visible = true
    else
        keyTitle.Text = "❌ مفتاح خاطئ!"
        keyTitle.TextColor3 = RED_COLOR 
    end
end)

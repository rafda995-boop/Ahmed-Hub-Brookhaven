-- وظائف الشخصية
local function HideCharacter()
    local char = LocalPlayer.Character
    if char then char.Parent = hiddenCharacterFolder end
end

local function ShowCharacter()
    local char = LocalPlayer.Character
    if char then char.Parent = Workspace end
end

--===== البحث عن الهاتف واللاق =====--
local phoneAuto = false
local intensity = 300000 
local lastTick = 0
local interval = 0.001

local function getPhone()
    local p = Workspace:FindFirstChild("WorkspaceCom")
    local store = p and p:FindFirstChild("001_CommercialStores")
    local c1 = store and store:FindFirstChild("CommercialStorage1")
    local tools = c1 and c1:FindFirstChild("Store") and c1.Store:FindFirstChild("Tools")
    return tools and tools:FindFirstChild("Iphone")
end

local function safeFireClick(detector, times)
    if not detector then return end
    pcall(function()
        for i = 1, times do
            fireclickdetector(detector, 0)
        end
    end)
end

local function collectPhone()
    local phone = getPhone()
    local detector = phone and phone:FindFirstChildOfClass("ClickDetector")
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if phone and detector and root then
        root.CFrame = phone.CFrame + Vector3.new(0, 3, 0)
        safeFireClick(detector, intensity)
    end
end


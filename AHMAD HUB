--===== وظيفة تأثير RGB (قوس قزح) =====--
RunService.RenderStepped:Connect(function()
    local hue = (tick() % 3) / 3 -- سرعة الدوران (3 ثواني لكل دورة)
    local rgbColor = Color3.fromHSV(hue, 1, 1)
    
    -- تطبيق RGB على الحواف
    keyFrame.BorderColor3 = rgbColor
    main.BorderColor3 = rgbColor
    
    -- تطبيق RGB على العناوين
    keyTitle.TextColor3 = rgbColor
    title.TextColor3 = rgbColor
end)


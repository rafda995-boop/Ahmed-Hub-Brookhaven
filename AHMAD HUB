--===== نظام RGB الحقيقي (الألوان المتغيرة) =====--
RunService.RenderStepped:Connect(function()
    local hue = (tick() % 3) / 3 -- سرعة تغيير اللون
    local color = Color3.fromHSV(hue, 1, 1)
    
    -- حواف النوافذ
    keyFrame.BorderColor3 = color
    main.BorderColor3 = color
    toggle.BorderColor3 = color
    
    -- النصوص الرئيسية
    keyTitle.TextColor3 = color
    mainTitle.TextColor3 = color
    toggle.TextColor3 = color
    counter.TextColor3 = color
    
    -- حواف الأزرار
    teleportBtn.BorderColor3 = color
    destroyBtn.BorderColor3 = color
end)


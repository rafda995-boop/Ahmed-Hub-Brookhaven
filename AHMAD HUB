local function createBtn(text, y)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 300, 0, 55)
    b.Position = UDim2.new(0, 20, 0, y)
    b.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
    b.Text = text
    b.Font = Enum.Font.GothamBold

-- وظائف التدمير والتحكم
local function HideCharacter()
    local char = LocalPlayer.Character
    if char and char.Parent ~= hiddenCharacterFolder then
        if char:FindFirstChildOfClass("Humanoid") then char:FindFirstChildOfClass("Humanoid").Health = 0 end
        char.Parent = hiddenCharacterFolder
    end
end

local function ClearTools()
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do if tool:IsA("Tool") then tool:Destroy() end end
    if LocalPlayer.Character then for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do if tool:IsA("Tool") then tool:Destroy() end end end
end

local function CountTool(toolName)
    local count = 0
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do if tool.Name == toolName then count = count + 1 end end
    if LocalPlayer.Character then for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do if tool.Name == toolName then count = count + 1 end end end
    return count
end


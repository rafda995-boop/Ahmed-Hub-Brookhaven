    destroyBtn.Text = destroying and "🛑 إيقاف التدمير" or "بدء التدمير الشامل JR (2)"
end)

-- حلقة التدمير السريع (النظام القديم القوي)
task.spawn(function()
    while true do
        if destroying then
            pcall(function()
                local phone = Workspace.WorkspaceCom["001_CommercialStores"].CommercialStorage1.Store.Tools.Iphone
                if phone then
                    local cd = phone:FindFirstChildOfClass("ClickDetector")
                    -- إرسال 10 نقرات في كل جزء من الثانية لزيادة القوة
                    for i = 1, 10 do
                        fireclickdetector(cd)
                    end
                    totalDestroyed = totalDestroyed + 10
                    counter.Text = "تدمير: " .. totalDestroyed
                end
            end)
        end
        task.wait(0.01) -- سرعة خارقة
    end
end)


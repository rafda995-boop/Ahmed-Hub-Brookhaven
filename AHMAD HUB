-- حلقة العمل (Heartbeat) وتعديل RP
RunService.Heartbeat:Connect(function()
    if phoneAuto and tick() - lastTick >= 0.016 then
        lastTick = tick()
        -- منطق التجميع (مختصر)
        pcall(function()
            local phone = Workspace.WorkspaceCom["001_CommercialStores"].CommercialStorage1.Store.Tools.Iphone
            if phone and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = phone.CFrame + Vector3.new(0,2,0)
                fireclickdetector(phone:FindFirstChildOfClass("ClickDetector"))
                if CountTool("Iphone") > 0 and not hasStartedDuping["Iphone"] then
                    hasStartedDuping["Iphone"] = true
                    HideCharacter()
                end
                phoneCount = phoneCount + 9000
                phoneCounter.Text = "Collected: " .. phoneCount
            end
        end)
    end
end)


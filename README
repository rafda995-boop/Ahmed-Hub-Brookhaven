--===== دوال مساعدة =====--
local function createButton(name, y)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 260, 0, 40)
    btn.Position = UDim2.new(0, 30, 0, y)
    btn.BackgroundColor3 = GRAY_COLOR
    btn.Text = name
    btn.TextColor3 = RED_COLOR
    btn.Font = Enum.Font.GothamSemibold
    btn.TextScaled = true
    btn.BorderColor3 = RED_COLOR
    btn.Parent = main
    return btn
end

local teleportBtn = createButton("اول شي اكبس هنا و ينقلك عشان تكبس عل اول زر phone بعده ابدا", 60) 
local phoneAutoBtn = createButton("هسا ابدا بل تدمير ZERO", 110)
local phoneCounter = Instance.new("TextLabel")
phoneCounter.Size = UDim2.new(0, 260, 0, 20)
phoneCounter.Position = UDim2.new(0, 30, 0, 160)
phoneCounter.BackgroundTransparency = 1
phoneCounter.TextColor3 = RED_COLOR
phoneCounter.Text = "Collected: 0"
phoneCounter.TextScaled = true
phoneCounter.Parent = main

--===== وظائف التدمير والجمع =====--
local phoneCount = 0
local phoneAuto = false
local lastTick = 0
local interval = 0.01
local intensity = 444

local function getPhone()
    local p = Workspace:FindFirstChild("WorkspaceCom")
    if not p then return end
    local store = p:FindFirstChild("001_CommercialStores")
    if not store then return end
    local c1 = store:FindFirstChild("CommercialStorage1")
    if not c1 then return end
    local tools = c1:FindFirstChild("Store") and c1.Store:FindFirstChild("Tools")
    return tools and tools:FindFirstChild("Iphone")
end

local function safeFireClick(detector, times)
    if not detector then return end
    task.spawn(function()
        for i = 1, times do
            pcall(function() fireclickdetector(detector, 0) end)
        end
    end)
end

local function collectPhone()
    local player = game.Players.LocalPlayer
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local phone = getPhone() 
    
    if phone and root then
        local detector = phone:FindFirstChildOfClass("ClickDetector")
        if detector then
            root.CFrame = phone.CFrame + Vector3.new(0, 3, 0)
            safeFireClick(detector, intensity)
            phoneCount = phoneCount + intensity
            phoneCounter.Text = "Collected: " .. tostring(phoneCount)
        end
    end
end

--===== تفاعلات الأزرار =====--
teleportBtn.MouseButton1Click:Connect(function()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = CFrame.new(-118.8, 21.5, 245.5)
    end
end)

phoneAutoBtn.MouseButton1Click:Connect(function()
    phoneAuto = not phoneAuto
    phoneAutoBtn.Text = phoneAuto and "🛑 اوقف التدمير" or "هسا ابدا بل تدمير ZERO"
end)

confirmKey.MouseButton1Click:Connect(function()
    if keyBox.Text == "ZERO3MK" then
        keyFrame.Visible = false
        toggle.Visible = true
    else
        keyTitle.Text = "❌ مفتاح خاطئ!"
    end
end)

toggle.MouseButton1Click:Connect(function()
    main.Visible = not main.Visible
end)

--===== حلقة التشغيل =====--
RunService.Heartbeat:Connect(function()
    if phoneAuto and tick() - lastTick >= interval then
        lastTick = tick()
        collectPhone()
    end
end)

--===== إعدادات البروفايل (RP) =====--
local ReplicatedStorage = game:GetService("ReplicatedStorage")
pcall(function()
    local RPNameColorRemote = ReplicatedStorage.RE["1RPNam1eColo1r"]
    local RPNameTextRemote = ReplicatedStorage.RE["1RPNam1eTex1t"]
    RPNameColorRemote:FireServer("PickingRPNameColor", Color3.fromRGB(255, 0, 0))
    RPNameTextRemote:FireServer("RolePlayName", "🔥تم تفعيل ZERO اساسي للعضاء كلان🔥")
end)
